NODE_ENV=development
PORT=23000
TZ=Asia/Shanghai

# PostgreSQL
DATABASE_HOST=127.0.0.1
DATABASE_PORT=15432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=claude_code_hub
DATABASE_SSLMODE=disable

# Redis
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Auth
ADMIN_TOKEN=dev-admin-token

# Web/direct auth session testing
SESSION_TOKEN_MODE=dual
ENABLE_SECURE_COOKIES=false

# Proxy behavior
ENABLE_RATE_LIMIT=true
ENABLE_CIRCUIT_BREAKER_ON_NETWORK_ERRORS=true
MAX_RETRY_ATTEMPTS_DEFAULT=2

# Optional explicit app URL for local smoke
APP_URL=http://127.0.0.1:23000

# Local bootstrap / mock upstreams
BOOTSTRAP_DEV_SEED=true
BOOTSTRAP_PROVIDER_BASE_URL=http://127.0.0.1:23000
