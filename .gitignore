# macOS system files
.DS_Store

# JetBrains IDEs (IntelliJ IDEA, WebStorm, etc.)
.idea/

# Claude local settings
.claude/

# Go build artifacts
bin/
tmp/
build-errors.log

# Configuration files (may contain secrets)
config.yaml
config.yml
.env

# Test coverage
coverage.out
coverage.html

